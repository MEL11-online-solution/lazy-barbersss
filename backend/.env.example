NODE_ENV=development
PORT=4000

# JWT secret — CHANGE FOR ANY NON-LOCAL ENV
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRES_IN=7d

# MySQL connection (matches docker-compose.yml in project root)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=lazy
DB_PASSWORD=lazypass
DB_NAME=lazybarbers
DB_CONNECTION_LIMIT=10

# SMS provider: console | twilio
SMS_PROVIDER=console

# Twilio (only needed if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email provider: console | sendgrid
EMAIL_PROVIDER=sendgrid

# SendGrid (only needed if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=lazybarbers.booking@gmail.com

# CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173

# Business name (used in SMS/email templates)
BUSINESS_NAME=Lazy Barbers
BUSINESS_PHONE=+61 416 065 592
BUSINESS_ADDRESS=15 Good St, Granville NSW

# Shop's local timezone (used for "available now" calculations)
SHOP_TIMEZONE=Australia/Sydney

# OpenAI (used by LazyBot chatbot — leave blank to fall back to keyword matching)
OPENAI_API_KEY=your-openai-api-key-here

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here

# Google OAuth (from https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:4000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
